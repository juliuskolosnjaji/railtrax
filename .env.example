# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/railtrax

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never NEXT_PUBLIC_

# ─── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── OAuth — Google ───────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://railtrax.eu

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Maps ─────────────────────────────────────────────────────────────────────
# Geoapify — used for static map image export
# Register at: https://apidash.geoapify.com → free tier (3000 req/day)
GEOAPIFY_API_KEY=

# ─── Internal ─────────────────────────────────────────────────────────────────
INTERNAL_SECRET=    # random secret for internal API calls, generate with: openssl rand -hex 32

# ─── Legal (Impressum / Datenschutz pages) ────────────────────────────────────
NEXT_PUBLIC_OPERATOR_NAME=Your Full Name
NEXT_PUBLIC_OPERATOR_STREET=Musterstraße 1
NEXT_PUBLIC_OPERATOR_CITY=12345 Musterstadt
NEXT_PUBLIC_OPERATOR_EMAIL=legal@railtrax.eu
NEXT_PUBLIC_OPERATOR_PHONE=    # optional
NEXT_PUBLIC_OPERATOR_VAT=      # optional — USt-IdNr. if applicable

# ─── AI (optional) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=    # server only

# ─── Formation APIs ───────────────────────────────────────────────────────────
# Marudor (DB/German trains) — no key needed, just keep User-Agent header

# Swiss Open Transport Data — SBB/Swiss trains
# Register at: https://api-manager.opentransportdata.swiss → formation_service_plan
# Auth: Bearer token
SWISS_OTD_API_KEY=

# NS (Dutch Railways)
# Register at: https://apiportal.ns.nl → subscribe to "Ns-App" product
# Auth: Ocp-Apim-Subscription-Key header
NS_API_KEY=

# SNCF Navitia — French trains (TGV, OUIGO, TER)
# Register at: https://navitia.io → free tier (3000 req/day)
# Auth: HTTP Basic, token as username, empty password
NAVITIA_API_KEY=

# Realtime Trains — UK trains (not yet configured)
# Register at: https://api.rtt.io (free, non-commercial)
# TODO: add when RTT_USERNAME + RTT_PASSWORD are available
# RTT_USERNAME=
# RTT_PASSWORD=
